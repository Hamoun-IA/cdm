# WC26 Cockpit — configuration
# Copier en .env et remplir avant le premier lancement.

PORT=3026
TZ_DISPLAY=Europe/Brussels

# football-data.org — https://www.football-data.org/client/register (gratuit)
FOOTBALL_DATA_TOKEN=

# The Odds API — https://the-odds-api.com (gratuit, 500 crédits/mois)
ODDS_API_KEY=

# API-Football — https://www.api-football.com (optionnel, 100 req/jour)
# Laisser vide pour désactiver le module compos/stats détaillées.
API_FOOTBALL_KEY=

# Bot Telegram dédié — créer via @BotFather
TELEGRAM_BOT_TOKEN=
# Ton chat id (le bot le donne au premier /start, ou via @userinfobot)
TELEGRAM_CHAT_ID=

# Betting — garde-fous serveur
BANKROLL_INITIAL=200
KELLY_FRACTION=0.125
MAX_STAKE_PCT=0.025
MIN_EDGE=0.03

# Analyse à la demande (module optionnel) : webhook du gateway OpenClaw.
# Sans ces deux variables, la fonction est désactivée proprement.
OPENCLAW_HOOK_URL=
OPENCLAW_HOOK_TOKEN=
